# STM32 CubeIDE Build Artifacts
**/Debug/
**/*.o
**/*.elf
**/*.bin
**/*.map
**/*.list
**/*.d
**/*.size.stdout
**/*.txt

# STM32 Objects and Dependencies
**/*.d
**/*.d.*
**/*.lst
**/*.cry
**/*.srec
**/*.hex

# CubeIDE Project Files (generated, not source)
**/.settings/
**/*.project
**/*.cproject
**/.cproject
**/.mxproject
**/.project

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
ENV/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS Files
.DS_Store
Thumbs.db

# Temporary/Downloaded files
*.tmp
*.bak
*.orig

# ST-Link logs
*.log

# RL Brain specific
RL_Brain/*.pyc
*.pyc
